# Copy this file to .env and fill in real values.
# Never commit .env or real credentials — see CLAUDE.md Secrets and Credentials section.
# Store the real value in Azure Key Vault, GitHub Actions Secrets, or an approved
# environment variable / deployment configuration.

# PostgreSQL connection string format:
# postgresql://<username>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://app_user:REPLACE_ME@localhost:5432/app_db
